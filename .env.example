BOT_TOKEN=your_bot_token_here

# Test/admin server. /council commands only sync/show here.
ADMIN_GUILD_ID=123456789012345678

# Live/public servers. User-facing commands sync/show here.
PUBLIC_GUILD_IDS=234567890123456789,345678901234567890

# Optional: old fallback; kept for backwards compatibility only.
# GUILD_ID=123456789012345678

MEDIA_CHANNEL_ID=0
TOPIC=science
PFP_THEME=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# Startup slash-command sync stays on every deploy.
AUTO_SYNC_ON_STARTUP=true

# Admin server roles allowed to use /council commands. Administrators are also allowed.
ADMIN_ROLE_NAMES=Tech,Admin,Council
